# CCC Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to the repository

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Port CCC listens on (default: 3000)
PORT=3000

# Root directory where all projects live (NFS mount in server mode)
PROJECT_ROOT=/mnt/sc-development

# Referral URL shown when Claude Code is not installed
CLAUDE_REFERRAL_URL=

# -----------------------------------------------------------------------------
# MariaDB (v1.1+)
# -----------------------------------------------------------------------------

DB_HOST=
DB_PORT=3306
DB_USER=ccc_app
DB_PASSWORD=
DB_NAME=ccc

# -----------------------------------------------------------------------------
# Authentication (v1.1+)
# -----------------------------------------------------------------------------

# Random string for session signing — generate with: openssl rand -hex 32
SESSION_SECRET=

# Shared secret for PatchPilot and other API integrations
CCC_API_TOKEN=

# -----------------------------------------------------------------------------
# Integrations (v1.1+)
# -----------------------------------------------------------------------------

# Forgejo
FORGEJO_URL=
FORGEJO_TOKEN=

# GitHub — personal access token (used for status diode + auto issue filing)
GITHUB_TOKEN=
GITHUB_REPO=

# PatchPilot base URL (used for status diode)
PATCHPILOT_URL=

# -----------------------------------------------------------------------------
# Anthropic (for Claude Code CLI on Dev-Web)
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=
