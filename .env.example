# CCC Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to the repository

# Port CCC listens on (default: 3000)
PORT=3000

# Referral URL shown when Claude Code is not installed (default: https://claude.ai)
CLAUDE_REFERRAL_URL=

# GitHub personal access token — used for automatic issue filing when parser degrades
GITHUB_TOKEN=

# GitHub repo in "owner/repo" format — target for auto-filed issues
GITHUB_REPO=
